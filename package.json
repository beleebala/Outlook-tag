{
  "name": "outlook-tag",
  "version": "0.1.0",
  "private": true,
  "description": "Outlook Web Add-in for applying and managing Outlook category tags.",
  "scripts": {
    "start": "webpack serve --mode development",
    "build:dev": "webpack --mode development && npm run validate:dev",
    "build": "webpack --mode production && npm run validate:prod",
    "certs:generate": "node scripts/generateDevCerts.cjs",
    "certs:install": "office-addin-dev-certs install",
    "certs:verify": "office-addin-dev-certs verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:dev": "node scripts/validateManifest.cjs dev",
    "validate:prod": "node scripts/validateManifest.cjs prod",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.326",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/office-js": "^1.0.517",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.5",
    "jsdom": "^29.1.1",
    "office-addin-dev-certs": "^2.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.2"
  },
  "engines": {
    "node": ">=24"
  }
}
